# =============================================================================
# OmniDrop AI — Environment Variables Template
# Copy this file to .env and fill in real values. NEVER commit .env
# =============================================================================

# --- App ----------------------------------------------------------------------
APP_ENV=local                                       # local | dev | sandbox | production
APP_SECRET_KEY=generate-with-openssl-rand-hex-32

# --- Supabase -----------------------------------------------------------------
# Get from: https://app.supabase.com/ → Project Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key                 # Anon key (safe for client-side)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key     # Server-side only — never expose to browser

# --- Anthropic ----------------------------------------------------------------
# Default model: claude-opus-4-6
ANTHROPIC_API_KEY=sk-ant-...

# --- AccuLynx -----------------------------------------------------------------
# AccuLynx API keys are per-location and stored in Supabase (not a global env var).
# Location managers enter their keys via the /settings UI.
# Rate limits: 30 req/sec per IP, 10 req/sec per API key

# --- Hookdeck (Webhook Gateway) -----------------------------------------------
# AccuLynx sends webhooks to Hookdeck → Hookdeck queues and forwards to FastAPI.
# Hookdeck signs each delivery with this secret — verified in backend/core/security.py.
# Get from: https://dashboard.hookdeck.com/ → Your Source → Signing Secret
HOOKDECK_SIGNING_SECRET=swhsec_...

# --- Celery + Redis -----------------------------------------------------------
# Local: Redis runs via Docker Compose on port 6379
# Render: Automatically injected from the omnidrop-redis Key Value service
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# --- WorkOS (Enterprise SSO / Magic Links) ------------------------------------
# Get from: https://dashboard.workos.com/
WORKOS_API_KEY=sk_...
WORKOS_CLIENT_ID=client_...
# Must be at least 32 characters — used to encrypt session cookies
# Generate: openssl rand -base64 32
WORKOS_COOKIE_PASSWORD=generate-with-openssl-rand-base64-32

# --- Unstructured.io (Omni-Parser) --------------------------------------------
# The core document parsing engine (PDFs, MSDS, Invoices, Manuals)
# Get from: https://app.unstructured.io/
UNSTRUCTURED_API_KEY=your-unstructured-api-key

# --- Sentry (Error Tracking) --------------------------------------------------
# Next.js frontend DSN (safe to expose to browser)
NEXT_PUBLIC_SENTRY_DSN=https://your-key@o0.ingest.sentry.io/0
# Python backend + Celery worker DSN (server-side only)
SENTRY_PYTHON_DSN=https://your-key@o0.ingest.sentry.io/0
# 1.0 = 100% of transactions (use 0.1 in production to reduce volume)
SENTRY_TRACES_SAMPLE_RATE=1.0
# Sentry webpack plugin — used during CI builds to upload source maps
SENTRY_ORG=your-sentry-org-slug
SENTRY_PROJECT=omnidrop-frontend

# --- Voyage AI (Embeddings) ---------------------------------------------------
# Used by Celery worker for document chunk embeddings (voyage-3, 1024-dim)
# Get from: https://dash.voyageai.com/
VOYAGE_AI_API_KEY=pa-...

# --- App Base URL -------------------------------------------------------------
# Base URL for this environment — used in bounce-back Slack deep links
# local: http://localhost:3000  |  dev: https://omnidrop.dev  |  prod: https://omnidrop.ai
APP_BASE_URL=http://localhost:3000

# --- Frontend (Next.js public vars — safe to expose to browser) ---------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_KEY=your-supabase-anon-key
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_WORKOS_REDIRECT_URI=http://localhost:3000/callback
NEXT_PUBLIC_APP_ENV=local
