# dlt secrets template — copy to secrets.toml and fill in real values
# NEVER commit secrets.toml — it is in .gitignore
#
# SECURITY RULE: The AccuLynx Bearer token must NEVER be hardcoded in
# pipeline scripts. It must always be read from this file at runtime.

[sources.acculynx]
api_key = "your-acculynx-api-key"
bearer_token = "your-acculynx-bearer-token"

[destination.supabase]
credentials = "postgresql://user:password@host:5432/postgres"
